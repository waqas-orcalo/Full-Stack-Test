# Application
NODE_ENV=development
PORT=8000

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:8000

# MongoDB connection key
# Local:  mongodb://localhost:27017/ecom_starter
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ecom_starter?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/ecom_starter

# JWT auth — generate a long random string for production
JWT_SECRET=change-me-in-production-please
JWT_EXPIRES_IN=7d

# Swagger basic auth (optional)
SWAGGER_USER=admin
SWAGGER_PASSWORD=
