# ---- Dependencies ----
node_modules/
**/node_modules/

# ---- Environment / secrets ----
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local
# keep example templates tracked
!.env.example
!**/.env.example

# ---- Uploaded product images (keep the folder, ignore contents) ----
images/*
!images/.gitkeep
**/images/*
!**/images/.gitkeep

# ---- Build output ----
dist/
**/dist/
build/
**/build/
.next/
**/.next/
out/
**/out/

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Caches / TS build info ----
*.tsbuildinfo
**/*.tsbuildinfo
.eslintcache
coverage/
**/coverage/

# ---- Editor / OS ----
.DS_Store
Thumbs.db
.idea/
.vscode/
